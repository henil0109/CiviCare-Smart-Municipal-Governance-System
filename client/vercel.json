{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://civicare-smart-municipal-governance.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://civicare-smart-municipal-governance.onrender.com/uploads/:path*"
        },
        {
            "source": "/static/:path*",
            "destination": "https://civicare-smart-municipal-governance.onrender.com/static/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}